generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model College {
  id                 Int      @id @default(autoincrement())
  name               String
  location           String
  fees               Int
  rating             Float
  description        String
  avgPackage         Float
  image              String

  placementPercent   Float
  highestPackage     Int
  courses            String

  createdAt          DateTime @default(now())
}